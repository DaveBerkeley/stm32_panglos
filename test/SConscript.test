
import os

BUILD_DIR = '../third_party/build'

Import("env")

#  Test files

files = [
    'thread.cpp',
    'queue.cpp',
    'semaphore.cpp',
]

includes = [
    '.',
    '../lib/panglos/src/',
]

print("Building libtest")

cflags = [ ]

env.Append(CPPPATH=includes)
env.Append(CFLAGS=cflags)

libtest = env.StaticLibrary(
    target=os.path.join(BUILD_DIR, 'libtest'),
    source=files
)
Default(libtest)

# FIN
